# ── PostgreSQL superuser ──────────────────────────────────────────────────────
POSTGRES_SUPERUSER_PASSWORD=

# ── Service DB passwords ──────────────────────────────────────────────────────
# These are the single source of truth: PostgresDB/init/03_create_roles.sh creates
# each role with these values, and the services' DATABASE_URLs reuse them.
USER_SERVICE_DB_PASSWORD=
SUBSCRIPTION_SERVICE_DB_PASSWORD=
DEBEZIUM_DB_PASSWORD=
DB_SERVICE_DB_PASSWORD=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:3000/
STRIPE_CANCEL_URL=http://localhost:3000/

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Must be identical for both services. Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowlist of frontend origins (never "*").
CORS_ORIGINS=http://localhost:3000